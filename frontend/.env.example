# Backend API URL (with trailing slash)
# Example: https://seyfibaba.com/
NEXT_PUBLIC_BASE_URL=

# Application URL (frontend, no trailing slash)
NEXT_APPLICATION_URL=

# PWA Status (0=disabled, 1=enabled)
NEXT_PWA_STATUS=0

# Node environment (development | production)
NODE_ENV=production

# Port (default 3000)
PORT=3000