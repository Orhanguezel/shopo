"use client";

import React, { useEffect, useState } from "react";
import { toast } from "react-toastify";
import InputCom from "../../Helpers/InputCom";
import LoaderStyleOne from "../../Helpers/Loaders/LoaderStyleOne";
import {
  useOtpResendApiMutation,
  useOtpVerifyApiMutation,
} from "@/redux/features/auth/apiSlice";

function OtpVerifyStep({
  phone,
  purpose = "register",
  initialExpiresIn = 300,
  onVerified,
  onBack,
}) {
  const [otpCode, setOtpCode] = useState("");
  const [countdown, setCountdown] = useState(initialExpiresIn);
  const [resendCountdown, setResendCountdown] = useState(60);

  const [otpVerifyApi, { isLoading: isVerifyLoading }] =
    useOtpVerifyApiMutation();
  const [otpResendApi, { isLoading: isResendLoading }] =
    useOtpResendApiMutation();

  useEffect(() => {
    setCountdown(initialExpiresIn);
  }, [initialExpiresIn]);

  useEffect(() => {
    if (countdown <= 0) {
      return undefined;
    }

    const timer = setInterval(() => {
      setCountdown((prev) => prev - 1);
    }, 1000);

    return () => clearInterval(timer);
  }, [countdown]);

  useEffect(() => {
    if (resendCountdown <= 0) {
      return undefined;
    }

    const timer = setInterval(() => {
      setResendCountdown((prev) => prev - 1);
    }, 1000);

    return () => clearInterval(timer);
  }, [resendCountdown]);

  const handleVerify = async () => {
    try {
      const response = await otpVerifyApi({
        phone,
        otp_code: otpCode,
        purpose,
      }).unwrap();

      toast.success("Phone number verified.");
      onVerified(response.token);
    } catch (error) {
      toast.error(error?.data?.message || "OTP verification failed.");
    }
  };

  const handleResend = async () => {
    try {
      const response = await otpResendApi({
        phone,
        purpose,
      }).unwrap();

      setCountdown(response.expires_in || 300);
      setResendCountdown(60);
      toast.success(response.message || "A new OTP has been sent.");
    } catch (error) {
      const retryAfter = error?.data?.retry_after;
      if (retryAfter) {
        setResendCountdown(retryAfter);
      }

      toast.error(error?.data?.message || "OTP resend failed.");
    }
  };

  return (
    <div className="rounded border border-qgray-border p-6">
      <div className="mb-5">
        <h2 className="text-2xl font-semibold text-qblack">Verify phone</h2>
        <p className="mt-2 text-sm text-qgray">
          Enter the 6-digit code sent to {phone}.
        </p>
      </div>

      <div className="mb-5">
        <InputCom
          placeholder="* * * * * *"
          label="OTP Code"
          name="otp_code"
          type="text"
          inputClasses="h-[50px]"
          value={otpCode}
          inputHandler={(e) =>
            setOtpCode(e.target.value.replace(/\D/g, "").slice(0, 6))
          }
        />
      </div>

      <div className="mb-5 flex items-center justify-between text-sm text-qgray">
        <span>Expires in {Math.max(0, countdown)}s</span>
        <button
          type="button"
          onClick={handleResend}
          disabled={resendCountdown > 0 || isResendLoading}
          className="font-medium text-qblack disabled:cursor-not-allowed disabled:opacity-50"
        >
          {resendCountdown > 0 ? `Resend in ${resendCountdown}s` : "Resend OTP"}
        </button>
      </div>

      <div className="flex flex-col gap-3 sm:flex-row">
        <button
          type="button"
          onClick={handleVerify}
          disabled={otpCode.length !== 6 || isVerifyLoading}
          className="black-btn flex h-[50px] w-full items-center justify-center bg-purple font-semibold disabled:cursor-not-allowed disabled:bg-opacity-50"
        >
          <span className="text-sm text-white">Verify and continue</span>
          {isVerifyLoading && (
            <span className="w-5" style={{ transform: "scale(0.3)" }}>
              <LoaderStyleOne />
            </span>
          )}
        </button>

        <button
          type="button"
          onClick={onBack}
          className="h-[50px] w-full border border-qgray-border text-sm font-semibold text-qblack"
        >
          Back
        </button>
      </div>
    </div>
  );
}

export default OtpVerifyStep;
